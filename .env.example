# ── LLM: set LLM_PROVIDER to groq OR gemini and provide the matching key ─────
LLM_PROVIDER=groq

GROQ_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY2=

# ── Image generation (optional) ───────────────────────────────────────────────
HF_TOKEN=
PEXELS_API_KEY=

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_BASE_URL=http://localhost:8000

# ── Other ─────────────────────────────────────────────────────────────────────
DEFAULT_NUM_SCENES=3
IMAGE_BACKEND=stub
SD_API_URL=http://127.0.0.1:7860
CHROMA_COLLECTION=montage_memory

# ... other variables ...
USE_VIDEO_MODEL=false
ALIBABA_CLOUD_API=

USE_AI_ANIMATION=true
STOCK_CLIP_STRATEGY=per_dialogue #per_scene or per_dialogue
